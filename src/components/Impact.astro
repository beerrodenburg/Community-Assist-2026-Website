---
import impact from '../data/impact.json';
const { feature } = impact;
---

<!-- ============ 4 · Impact stories ============ -->
<section class="section" id="impact" aria-labelledby="impact-h">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">{impact.eyebrow}</p>
      <h2 class="h2" id="impact-h">{impact.heading}</h2>
    </div>
    <div class="impact-grid">
      <article class="story story-feature reveal">
        <div class="story-video">
          <video muted loop playsinline preload="none"
                 poster={feature.poster}
                 aria-label={feature.videoAlt}>
            <source src={feature.videoWebm} type="video/webm" />
            <source src={feature.videoMp4} type="video/mp4" />
            <img src={feature.poster} width={feature.posterWidth} height={feature.posterHeight} alt={feature.posterAlt} />
          </video>
          <button type="button" class="video-unmute" aria-label="Unmute Chintya's testimonial">
            <svg class="icon-play" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg class="icon-muted" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            <svg class="icon-unmuted" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/></svg>
          </button>
        </div>
        <div class="story-body">
          <p class="s-tag">{feature.tag}</p>
          <h3 class="s-name">{feature.name}</h3>
          {feature.paragraphs.map((t) => <p class="s-text">{t}</p>)}
        </div>
      </article>
      <div class="story-row">
        {impact.sideStories.map((s) => (
          <article class={`story story-side reveal ${s.delay}`}>
            <div class="story-img"><img src={s.img} width={s.width} height={s.height} alt={s.alt} loading="lazy" style={`object-position:${s.objectPosition}`} /></div>
            <div class="story-body">
              <p class="s-tag">{s.tag}</p>
              <h3 class="s-name">{s.name}</h3>
              <p class="s-text">{s.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
