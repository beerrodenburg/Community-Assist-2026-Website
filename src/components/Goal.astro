---
import goal from '../data/goal.json';
---

<!-- ============ 6 · 2026 goal (brand moment) ============ -->
<section class="goal section" aria-labelledby="goal-h">
  <img class="goal-student left" src={goal.studentLeft} width={goal.studentLeftWidth} height={goal.studentLeftHeight} alt="" aria-hidden="true" loading="lazy" />
  <img class="goal-student right" src={goal.studentRight} width={goal.studentRightWidth} height={goal.studentRightHeight} alt="" aria-hidden="true" loading="lazy" />
  <div class="wrap">
    <p class="eyebrow"><svg class="heart" viewBox="0 0 24 24" aria-hidden="true"><use href="#i-heart"/></svg> {goal.eyebrow}</p>
    <h2 class="goal-num" id="goal-h">{goal.amount}</h2>
    <p class="goal-sub" set:html={goal.subHtml} />
    <!-- Progress reflects goal.progress (data-progress); main.js animates the fill width and aria-valuenow. -->
    <div class="progress">
      <div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow={goal.progress} aria-label="Funding toward our 2026 goal"><div class="progress-fill" data-progress={goal.progress}></div></div>
      <div class="progress-meta"><span>{goal.progressLabelLeft}</span><span><b>{goal.progress}%</b> toward our goal</span></div>
    </div>
    <div class="goal-cta">
      <a href={goal.primaryCta.href} class="btn btn--white btn--lg">{goal.primaryCta.label}</a>
      <a href={goal.secondaryCta.href} class="btn btn--ghost-light btn--lg">{goal.secondaryCta.label}</a>
    </div>
  </div>
</section>
