---
import sponsors from '../data/sponsors.json';
---

<!-- ============ 9 · Sponsors ============ -->
<section class="section" id="sponsors" aria-labelledby="sponsors-h">
  <div class="wrap">
    <div class="section-head center reveal">
      <p class="eyebrow" style="justify-content:center">{sponsors.eyebrow}</p>
      <h2 class="h2" id="sponsors-h">{sponsors.heading}</h2>
      <p class="lead muted" style="margin-top:14px">{sponsors.lead}</p>
    </div>

    <div class="sponsor-tier reveal">
      <p class="st-label">Champions</p>
      <div class="sponsor-grid champions">
        {sponsors.champions.map((s) => (
          <div class="sponsor-chip"><img class={`slogo${s.color ? ' slogo--color' : ''}`} src={s.src} width={s.width} height={s.height} alt={s.alt} loading="lazy" /></div>
        ))}
      </div>
    </div>

    <div class="sponsor-tier reveal">
      <p class="st-label">Game Changers</p>
      <div class="sponsor-grid changers">
        {sponsors.gameChangers.map((s) => (
          <div class="sponsor-chip"><img class={`slogo${s.color ? ' slogo--color' : ''}`} src={s.src} width={s.width} height={s.height} alt={s.alt} loading="lazy" /></div>
        ))}
      </div>
    </div>

    <div class="sponsor-tier reveal">
      <p class="st-label">Community Heroes</p>
      <ul class="hero-names">
        {sponsors.communityHeroes.map((n) => <li class="hero-name">{n}</li>)}
        <li class="hero-name hero-name--more">{sponsors.communityHeroesMore}</li>
      </ul>
    </div>

    <p class="sponsor-cta reveal">{sponsors.ctaText} <a href={sponsors.ctaLink.href}>{sponsors.ctaLink.label}</a></p>
  </div>
</section>
